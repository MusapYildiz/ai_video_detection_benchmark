# Diger acik kaynak modeller (ayri public repolar, referans icin README'de link var)
other_models/

# Checkpoint ve model agirliklari
checkpoints/
*.pt
*.pth
*.ckpt

# Datasetler ve manifestler (path/label listeleri de dahil)
datasets/
*.jsonl
*.parquet
*.mp4
*.avi
